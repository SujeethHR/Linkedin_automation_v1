# ── Abacus.AI ChatLLM (RouteLLM) ──────────────────────────────────────────────
# Get your API key: https://abacus.ai/app/route-llm-apis
ABACUS_API_KEY=your_abacus_api_key_here

# Base URL — use this for self-serve accounts (default)
ABACUS_BASE_URL=https://routellm.abacus.ai/v1

# Model to use — "route-llm" auto-routes, or pick a specific one:
#   claude-sonnet-4-6, gpt-4o, gemini-2.5-flash, deepseek-v3.1, llama-3.3-70B
ABACUS_MODEL=claude-sonnet-4-6

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# Get token: https://developer.linkedin.com → your app → Auth → OAuth 2.0 tools
LINKEDIN_TOKEN=your_linkedin_access_token_here

# Your LinkedIn member URN
LINKEDIN_URN=urn:li:person:XXXXXXXX
